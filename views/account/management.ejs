<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head') %>
    <title>Account Management</title>
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/nav') %>

    <main>
        <h1>Account Management</h1>
        
        <h2>Welcome, <%= account.account_firstname %> <%= account.account_lastname %></h2>
        
        <p>Account Type: <%= account.account_type %></p>
        
        <!-- Inventory Management - only for Employee or Admin -->
        <% if (account.account_type === 'Employee' || account.account_type === 'Admin') { %>
            <div class="inventory-section">
                <h3>Inventory Management</h3>
                <a href="/inv" class="btn">Manage Inventory</a>
            </div>
        <% } %>
        
        <div class="account-links">
            <a href="/account/update" class="btn">Update Account Information</a>
            <a href="/account/logout" class="btn">Logout</a>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>
</html>