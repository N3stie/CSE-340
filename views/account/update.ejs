<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head') %>
    <title>Update Account</title>
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/nav') %>

    <main>
        <h1>Update Account Information</h1>
        
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-error"><%= error %></div>
        <% } %>
        
        <% if (typeof message !== 'undefined' && message) { %>
            <div class="alert alert-success"><%= message %></div>
        <% } %>
        
        <!-- Form 1: Update Account Info -->
        <h2>Edit Profile</h2>
        <form action="/account/update" method="POST" class="custom-form">
            <input type="hidden" name="account_id" value="<%= account.account_id %>">
            
            <div class="form-group">
                <label for="firstname">First Name *</label>
                <input type="text" id="firstname" name="firstname" value="<%= account.account_firstname %>" required>
            </div>
            
            <div class="form-group">
                <label for="lastname">Last Name *</label>
                <input type="text" id="lastname" name="lastname" value="<%= account.account_lastname %>" required>
            </div>
            
            <div class="form-group">
                <label for="email">Email *</label>
                <input type="email" id="email" name="email" value="<%= account.account_email %>" required>
            </div>
            
            <button type="submit" class="btn">Update Profile</button>
        </form>
        
        <!-- Form 2: Change Password -->
        <h2>Change Password</h2>
        <form action="/account/change-password" method="POST" class="custom-form">
            <input type="hidden" name="account_id" value="<%= account.account_id %>">
            
            <div class="form-group">
                <label for="password">New Password * (min 6 characters)</label>
                <input type="password" id="password" name="password" required minlength="6">
            </div>
            
            <div class="form-group">
                <label for="confirm_password">Confirm New Password *</label>
                <input type="password" id="confirm_password" name="confirm_password" required>
            </div>
            
            <button type="submit" class="btn">Change Password</button>
        </form>
        
        <p><a href="/account/management">Back to Account Management</a></p>
    </main>

    <%- include('../partials/footer') %>
</body>
</html>