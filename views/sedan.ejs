<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Sedan - CSE Motors</title>
</head>
<body>
    <%- include('partials/header') %>
    <%- include('partials/nav') %>

    <main>
        <h2>Sedan Vehicles</h2>
        <p>Browse our collection of premium sedans</p>

        <div class="vehicle-card">
            <div class="vehicle-image">
                <img src="/images/sedan.png" alt="Sedan" onerror="this.src='https://placehold.co/600x400?text=Sedan'">
            </div>
            <div class="vehicle-info">
                <h3>Lexus ES - Luxury Sedan</h3>
                <p class="price">$35,000</p>
                <p class="description">The Lexus ES combines elegant design with exceptional comfort. Known for its whisper-quiet cabin, smooth ride, and premium materials throughout.</p>
                <ul class="specs">
                    <li>Engine: 3.5L V6 / 2.5L Hybrid</li>
                    <li>MPG: 22 City / 32 Highway</li>
                    <li>Seats: 5 Passengers</li>
                    <li>Transmission: 8-Speed Automatic</li>
                </ul>
                <button class="reserve-btn" onclick="openReserveForm()">Click for Reserve</button>
            </div>
        </div>

        <div id="reserveModal" class="modal">
            <div class="modal-content">
                <span class="close">&times;</span>
                <h3>Reserve This Vehicle</h3>
                <form id="reserveForm">
                    <input type="text" placeholder="Full Name" required>
                    <input type="email" placeholder="Email" required>
                    <input type="tel" placeholder="Phone Number" required>
                    <textarea placeholder="Message (optional)"></textarea>
                    <button type="submit">Submit Reservation</button>
                </form>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>

    <script>
        function openReserveForm() {
            document.getElementById('reserveModal').style.display = 'block';
        }

        document.getElementById('reserveForm').addEventListener('submit', function(e) {
            e.preventDefault();
            alert('Thank you! We will contact you soon.');
            document.getElementById('reserveModal').style.display = 'none';
            this.reset();
        });

        document.querySelector('.close').onclick = function() {
            document.getElementById('reserveModal').style.display = 'none';
        }

        window.onclick = function(event) {
            if (event.target == document.getElementById('reserveModal')) {
                document.getElementById('reserveModal').style.display = 'none';
            }
        }
    </script>
</body>
</html>