<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>

<body>
    <%- include('partials/header') %>
    <%- include('partials/nav') %>
    
    <main>
        <!-- Removed the "Welcome to CSE Motors!" line -->
        
        <section class="featured-vehicle">
            <h3>2024 Tesla Model 3</h3>
            <ul>
                <li>0-60 mph in 3.1 seconds</li>
                <li>358 miles range</li>
                <li>Autopilot included</li>
                <li>All-electric AWD</li>
            </ul>
            <button>Own Today</button>
        </section>

        <!-- Mobile Reviews Section (only shows on mobile) -->
        <section class="reviews mobile-only">
            <h3>Tesla Model 3 Reviews</h3>
            <ul>
                <li>"Best EV I've ever driven!" (5/5)</li>
                <li>"The acceleration is insane!" (5/5)</li>
                <li>"Love the minimalistic interior." (4.5/5)</li>
                <li>"Supercharging network is amazing." (5/5)</li>
                <li>"Best purchase I've made." (5/5)</li>
            </ul>
        </section>
        
        <section class="upgrades">
            <h3>Tesla Accessories</h3>
            <div class="upgrades-grid">
                <div class="upgrade-item">
                    <h4>Wall Connector</h4>
                    <p>"Fast home charging made easy." (4.5/5)</p>
                </div>
                <div class="upgrade-item">
                    <h4>All-Weather Mats</h4>
                    <p>"Perfect fit, great quality." (4.8/5)</p>
                </div>
                <div class="upgrade-item">
                    <h4>Chrome Delete Kit</h4>
                    <p>"Transformed the look completely." (4.7/5)</p>
                </div>
                <div class="upgrade-item">
                    <h4>Carbon Fiber Spoiler</h4>
                    <p>"Sporty look, easy install." (4.6/5)</p>
                    <p>"Adds that extra touch!" (5/5)</p>
                </div>
            </div>
        </section>
    </main>
    
    <%- include('partials/footer') %>
</body>
</html>