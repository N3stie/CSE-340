<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <%- include('partials/header') %>
    <%- include('partials/nav') %>
    
    <main>
        <h2>Welcome to CSE Motors!</h2>
        
        <section class="featured-vehicle">
            <h3>DMC Delorean</h3>
            <ul>
                <li>3 Cup holders</li>
                <li>Superman doors</li>
                <li>Fuzzy dice!</li>
            </ul>
            <button>Own Today</button>
        </section>

        <!-- Mobile Reviews Section (only shows on mobile) -->
         <!-- If the User used in Phone -->
        <section class="reviews mobile-only">
            <h3>DMC Delorean Reviews</h3>
            <ul>
                <li>"So fast it's almost like traveling in time." (4/5)</li>
                <li>"Coolest ride on the road." (4/5)</li>
                <li>"I'm feeling McFly!" (5/5)</li>
                <li>"The most futuristic ride of our day." (4.5/5)</li>
                <li>"80's livin and I love it!" (5/5)</li>
            </ul>
        </section>
        
        <section class="upgrades">
            <h3>Delorean Upgrades</h3>
            <div class="upgrades-grid">
                <div class="upgrade-item">
                    <h4>Flux Capacitor</h4>
                    <p>"So fast it's almost like traveling in time." (4/5)</p>
                </div>
                <div class="upgrade-item">
                    <h4>Flame Decals</h4>
                    <p>"Coolest ride on the road." (4/5)</p>
                </div>
                <div class="upgrade-item">
                    <h4>Bumper Stickers</h4>
                    <p>"I'm feeling McFly!" (5/5)</p>
                </div>
                <div class="upgrade-item">
                    <h4>Hub Caps</h4>
                    <p>"The most futuristic ride of our day." (4.5/5)</p>
                    <p>"80's livin' and I love it!" (5/5)</p>
                </div>
            </div>
        </section>
    </main>
    
    <%- include('partials/footer') %>
