<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Custom Order - CSE Motors</title>
</head>
<body>
    <%- include('partials/header') %>
    <%- include('partials/nav') %>

    <main>
        <h2>Custom Order Request</h2>
        <p>Tell us what kind of custom vehicle you want, and we'll contact you soon!</p>

        <form action="/inv/custom/submit" method="POST" class="custom-form">
            <div class="form-group">
                <label for="name">Full Name *</label>
                <input type="text" id="name" name="name" required>
            </div>

            <div class="form-group">
                <label for="email">Email Address *</label>
                <input type="email" id="email" name="email" required>
            </div>

            <div class="form-group">
                <label for="phone">Phone Number *</label>
                <input type="tel" id="phone" name="phone" required>
            </div>

            <div class="form-group">
                <label for="vehicle_type">Vehicle Type *</label>
                <select id="vehicle_type" name="vehicle_type" required>
                    <option value="">Select a type</option>
                    <option value="Sedan">Sedan</option>
                    <option value="SUV">SUV</option>
                    <option value="Truck">Truck</option>
                    <option value="Sports Car">Sports Car</option>
                    <option value="Luxury">Luxury</option>
                </select>
            </div>

            <div class="form-group">
                <label for="budget">Budget Range</label>
                <select id="budget" name="budget">
                    <option value="">Select budget</option>
                    <option value="Under $20,000">Under $20,000</option>
                    <option value="$20,000 - $30,000">$20,000 - $30,000</option>
                    <option value="$30,000 - $50,000">$30,000 - $50,000</option>
                    <option value="$50,000+">$50,000+</option>
                </select>
            </div>

            <div class="form-group">
                <label for="message">Special Requests</label>
                <textarea id="message" name="message" rows="4" placeholder="Color, features, etc..."></textarea>
            </div>

            <button type="submit" class="submit-btn">Submit Request</button>
        </form>
    </main>

    <%- include('partials/footer') %>
</body>
</html>